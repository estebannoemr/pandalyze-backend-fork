JWT_SECRET_KEY=your_secret_key_here

# Admin bootstrap: si ambos están definidos, al arrancar la app se crea
# automáticamente este usuario con rol admin (o se lo promueve si ya existía).
# Si el usuario ya existía y ya era admin, no se sobrescribe la contraseña.
ADMIN_EMAIL=your_email_here
ADMIN_PASSWORD=your_password_here

# Seed demo: si está en "1", "true" o "yes", al arrancar la app se crean
# automáticamente 2 docentes (Sofía y Claudia) y 6 alumnos (3 por docente).
# Idempotente: no toca usuarios ya existentes. Para desactivar, dejarla
# vacía o quitarla. La password por defecto se puede sobrescribir con
# SEED_DEMO_PASSWORD (default: "demo1234").
SEED_DEMO_USERS=1
SEED_DEMO_PASSWORD=demo1234