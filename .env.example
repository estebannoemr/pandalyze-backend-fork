
FLASK_DEBUG=0  # 1: debug, 0: no debug
JWT_SECRET_KEY=your_secret_key_here

# Admin bootstrap: si ambos están definidos, al arrancar la app se crea
# automáticamente este usuario con rol admin (o se lo promueve si ya existía).
# Si el usuario ya existía y ya era admin, no se sobrescribe la contraseña.
ADMIN_EMAIL=your_email_here
ADMIN_PASSWORD=your_password_here

# Seed demo: si está en "1", "true" o "yes", al arrancar la app se crean
# automáticamente 2 docentes (Sofía y Claudia) y 6 alumnos (3 por docente).
# Idempotente: no toca usuarios ya existentes. Para desactivar, dejarla
# vacía o quitarla. La password por defecto se puede sobrescribir con
# SEED_DEMO_PASSWORD (default: "demo1234").
SEED_DEMO_USERS=1
SEED_DEMO_PASSWORD=demo1234

# URL pública del frontend, usada para construir el link de reset password
# que se envía por mail. Si no se setea, se usa http://localhost:3000.
FRONTEND_URL=http://localhost:3000

# SMTP: si no están definidas, los emails de reset password se
# loguean en consola en vez de enviarse. Para Gmail usar contraseña de app.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=app_password
SMTP_FROM=tu_email@gmail.com
SMTP_USE_TLS=1

# Base de datos:
# Si no se define DATABASE_URL, la app puede caer a SQLite en desarrollo.
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/pandalyze

# Alternativa compatible con la config actual si se prefiere variables separadas:
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_HOST=localhost
# DB_NAME=pandalyze
